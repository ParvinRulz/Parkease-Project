doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1')
  title Vehicle Registration
  // Bootstrap CSS
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')
// TOPBAR
nav.navbar.navbar-expand-lg.navbar-dark.bg-dark.px-4
  .d-flex.align-items-center
    img(src='Assets/logo-P.png' width='60')
    span.text-white.ms-2.fw-bold ParkVille
  button.navbar-toggler(type='button' data-bs-toggle='collapse' data-bs-target='#navMenu')
    span.navbar-toggler-icon
  #navMenu.collapse.navbar-collapse
    .navbar-nav.ms-auto
      a.nav-link(href='#') Reports
      a.nav-link(href='#') Attendant
      a.nav-link.active(href='#') Register
      a.nav-link(href='#') Battery
      a.nav-link(href='#') Tyre-hire
      a.nav-link(href='#') Signout
      a.nav-link(href='#') Logout
  // USER
  .text-white.text-end.ms-3
    .fw-semibold Parvin Rulz
    small ATTENDANT
// MAIN
.container.py-4
  h2.fw-bold Vehicle Registration
  p.text-muted
    | Registering incoming vehicles for secure entry and automated billing
  // CARD
  .card.shadow-sm.p-4.mt-3
    h5.mb-3 Driver Information
    .row.g-3
      // Driver Name
      .col-md-6
        label.form-label Driver Name
        input.form-control(type='text' placeholder='Enter driver full name' name='driverName')
      // Vehicle Type
      .col-md-6
        label.form-label Vehicle Type
        select#vehicleType.form-select
          option Truck
          option Personal Car
          option Taxi
          option Coaster
          option Boda-boda
      // Number Plate
      .col-md-6
        label.form-label Number Plate
        input.form-control(type='text' placeholder='UBA-1234' name='numberPlate')
        #plateError.text-danger.small
      // Model & Color
      .col-md-6
        label.form-label Vehicle Model &amp; Color
        input.form-control(type='text' placeholder='e.g Toyota Camry, Silver' name='vehicleModel')
      // Arrival
      .col-md-6
        label.form-label Arrival Time &amp; Date
        input#arrivalTime.form-control(type='datetime-local' name='arrivalTime')
        #arrivalError.text-danger.small
      // Phone
      .col-md-6
        label.form-label Phone Number
        input#phoneNumber.form-control(type='text' placeholder='+256XXXXXXXXX' name='phoneNumber')
        #phoneError.text-danger.small
      // NIN
      #ninContainer.col-md-6
        label.form-label NIN Number
        input#ninNumber.form-control(type='text' placeholder='Enter NIN' name='ninNumber')
    // BUTTONS
    .mt-4.d-flex.gap-3.flex-wrap
      button.btn.btn-warning.fw-semibold
        | Register &amp; Print Receipt
      button.btn.btn-outline-secondary
        | Clear Form
// JS
script(src='Public/JAVASCRIPT/validateregex.js')
script.
  document.addEventListener('DOMContentLoaded', function() {
  const vehicleTypeSelect = document.getElementById('vehicleType');
  const ninContainer = document.getElementById('ninContainer');
  const ninInput = document.getElementById('ninNumber');
  // Hide NIN initially
  ninContainer.style.display = 'none';
  // Auto-fill current datetime
  const now = new Date();
  document.getElementById('arrivalTime').value = now.toISOString().slice(0,16);
  vehicleTypeSelect.addEventListener('change', function() {
  if (this.value === 'Boda-boda') {
  ninContainer.style.display = 'block';
  ninInput.setAttribute('required', 'required');
  } else {
  ninContainer.style.display = 'none';
  ninInput.removeAttribute('required');
  ninInput.value = '';
  }
  });
  });
// Bootstrap JS
script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')
