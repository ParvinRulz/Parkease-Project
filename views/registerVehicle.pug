doctype html
html(lang='en')
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1')
    title Vehicle Registration

    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')

    style.
      body {
        background-color: #f8fafc;
      }

      .dark-blue {
        background-color: #0f172a !important;
        color: #fff !important;
      }

      .dark-blue-outline {
        border: 1px solid #0d1b2a !important;
        color: #0f172a !important;
        background-color: transparent !important;
      }

      .yellow-btn {
        background-color: #ffc107 !important;
        color: #0f172a !important;
        border: none !important;
      }

      .yellow-btn:hover {
        background-color: #e0a800 !important;
      }

      .form-section-title {
        border-left: 4px solid #ffc107;
        padding-left: 10px;
      }

  body
    // NAVBAR
    nav.navbar.navbar-expand-lg.dark-blue.shadow-sm
      .container-fluid.px-4
        a.navbar-brand.d-flex.align-items-center.text-white(href="#")
          img(src='' width='50')
          span.ms-2.fw-bold ParkVille

        button.navbar-toggler(type='button' data-bs-toggle='collapse' data-bs-target='#navMenu')
          span.navbar-toggler-icon

        #navMenu.collapse.navbar-collapse
          ul.navbar-nav.ms-auto.mb-2.mb-lg-0
            li.nav-item
              a.nav-link.text-white(href='#') Reports
            li.nav-item
              a.nav-link.text-white(href='#') Attendant
            li.nav-item
              a.nav-link.active.text-warning.fw-semibold(href='#') Register
            li.nav-item
              a.nav-link.text-white(href='#') Battery
            li.nav-item
              a.nav-link.text-white(href='#') Tyre-hire
            li.nav-item
              a.nav-link.text-white(href='#') Signout
            li.nav-item
              a.nav-link.text-white(href='#') Logout

        .text-white.text-end.ms-3.d-none.d-lg-block
          div.fw-semibold Ruth Rise
          small ATTENDANT

    // MAIN CONTENT
    .container.py-5
      .row.justify-content-center
        .col-lg-10

          // HEADER
          .mb-4
            h2.fw-bold Vehicle Registration
            p.text-muted.mb-0 Register incoming vehicles for secure entry and automated billing

          // CARD
          .card.shadow.border-0.rounded-4
            .card-body.p-4.p-md-5

              form(action="/registerVehicle" method="POST" enctype="multipart/form-data")

                // SECTION TITLE
                h5.fw-bold.mb-4.form-section-title Driver Information

                .row.g-4

                  .col-md-6
                    label.form-label.fw-semibold Driver Name
                    input.form-control(type='text' name='driverName' placeholder='Enter full name')

                  .col-md-6
                    label.form-label.fw-semibold Vehicle Type
                    select.form-select(name='vehicleType')
                      option(value="" disabled selected) Select vehicle type
                      option Truck
                      option Personal Car
                      option Taxi
                      option Coaster
                      option Boda-boda

                  .col-md-6
                    label.form-label.fw-semibold Number Plate
                    input.form-control(type='text' name='numberPlate' placeholder='UBA-1234')
                    #plateError.text-danger.small.mt-1

                  .col-md-6
                    label.form-label.fw-semibold Vehicle Model
                    input.form-control(type='text' name='vehicleModel' placeholder='e.g Toyota Camry')

                  .col-md-6
                    label.form-label.fw-semibold Vehicle Color
                    input.form-control(type='text' name='vehicleColor' placeholder='e.g Silver')

                  .col-md-6
                    label.form-label.fw-semibold Vehicle Image
                    input.form-control(type='file' name='vehicleImage')

                  .col-md-6
                    label.form-label.fw-semibold Phone Number
                    input.form-control(type='text' name='phoneNumber' placeholder='0700000000')
                    #phoneError.text-danger.small.mt-1

                  .col-md-6
                    label.form-label.fw-semibold.text-danger(for='ninNumber') NIN Number(Required for Boda-bodas)
                    input#ninNumber.form-control.border-danger(type='text' placeholder='Enter valid NIN' name='ninNumber')

                // BUTTONS
                .mt-5.d-flex.flex-wrap.gap-3.justify-content-between
                  button.btn.yellow-btn.fw-semibold.px-5.py-2(type="submit") Register Vehicle
                  button.btn.dark-blue-outline.px-5.py-2(type="reset") Clear Form

    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')
    script(src='/js/vehicleRegister.js')