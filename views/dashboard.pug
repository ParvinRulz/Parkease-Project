doctype html
html(lang="en")
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title ParkVille Dashboard

    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet")

    style.
      .dark-nav {
        background-color: #0f172a;
      }
      .card-soft {
        border: none;
        border-radius: 16px;
        box-shadow: 0 6px 18px rgba(0,0,0,0.08);
      }
      .stat-value {
        font-size: 1.6rem;
        font-weight: bold;
      }

  body
    // ================= NAVBAR =================
    nav.navbar.navbar-expand-lg.bg-white.shadow-sm
      .container-fluid

        a.navbar-brand.fw-bold(style='color:#0f172a;' href='/login') ParkVille

        button.navbar-toggler(type='button' data-bs-toggle='collapse' data-bs-target='#navbarNav')
          span.navbar-toggler-icon

        #navbarNav.collapse.navbar-collapse
          ul.navbar-nav.me-auto.mb-2.mb-lg-0
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/signup") Signup
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/login") Login
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/login") Dashboard
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/users") Manage Users
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/registerVehicle") Vehicle
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/signout") Vehicle Signout
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/battery") Battery Services
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/tyre") Tyre Clinic

    
          .d-flex.align-items-center.gap-3
            span.text-white.small Admin
            a.btn.btn-outline-light.btn-sm(href='/logout') Logout

    .container.py-4

      // SEARCH BAR
      .mb-4
        input.form-control.form-control-lg(type='text' placeholder='Search vehicle by number plate...' name='search')

      // STATS (DYNAMIC READY)
      .row.g-4.mb-4

        .col-md-3
          .card.card-soft.p-3.text-center
            h6.text-muted Parked Vehicles
            .stat-value= parkedVehicles || 0

        .col-md-3
          .card.card-soft.p-3.text-center
            h6.text-muted Total Revenue
            .stat-value UGX #{totalRevenue ? totalRevenue.toLocaleString() : 0}

        .col-md-3
          .card.card-soft.p-3.text-center
            h6.text-muted Available Slots
            .stat-value= availableSlots || 0

        .col-md-3
          .card.card-soft.p-3.text-center
            h6.text-muted Active Attendants
            .stat-value= activeAttendants || 0

      // QUICK ACTIONS
      .d-flex.gap-3.mb-4
        a.btn.btn-primary(href='/register') Register Vehicle
        a.btn.btn-outline-dark(href='/signOut') Vehicle Sign Out

      // TABLE
      .card.card-soft
        .card-header.bg-white
          h5.mb-0 Vehicle Activity

        .table-responsive
          table.table.table-hover.mb-0.align-middle
            thead.table-light
              tr
                th Vehicle Type
                th Number Plate
                th Time In
                th Status
                th Services

            tbody
              if vehicles && vehicles.length > 0
                each vehicle in vehicles
                  tr
                    td= vehicle.type
                    td= vehicle.numberPlate
                    td= vehicle.timeIn
                    td
                      if vehicle.status === 'Parked'
                        span.badge.bg-success Parked
                      else
                        span.badge.bg-secondary Signed Out
                    td= vehicle.services || 'None'
              else
                tr
                  td.text-center.py-4.text-muted(colspan='5')
                    | No vehicle records available

    // FOOTER
    footer.dark-nav.text-white.text-center.py-3.mt-5
      p.mb-0 ParkVille Smart Parking System © 2026

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js")