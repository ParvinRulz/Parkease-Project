extends layout
block content 
  .container.min-vh-100.d-flex.justify-content-center.align-items-center
    .card.shadow-lg.border-0.rounded-4(style='width: 100%; max-width: 450px;')
      .card-body.p-5
        h2.text-center.fw-bold.mb-2 Activities
        p.text-center.text-muted.mb-4 Enter the activity details.
        form(method='post' action='/add-transaction')
          .mb-4
            label.form-label.fw-semibold(for='registeredToday') Registered Today
            input#registeredToday.form-control(type='number' name='registeredToday' )
            label.form-label.fw-semibold(for='vehiclesParked') Vehicles Parked
            input#vehiclesParked.form-control(type='number' name='vehiclesParked' )
            label.form-label.fw-semibold(for='signedOutToday') Signed Out Today
            input#signedOutToday.form-control(type='number' name='signedOutToday' )
            label.form-label.fw-semibold(for='revenueToday') Revenue Today
            input#revenueToday.form-control(type='number' name='revenueToday' )
          button.btn.btn-primary.w-100.py-2.fw-bold.rounded-3(type='submit') Add Activity
  script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')