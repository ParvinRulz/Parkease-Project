doctype html
head
  meta(charset='UTF-8')
  // Makes the page responsive on mobile
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  // Page title
  title ParkVille Daily Reports
  // Link to external CSS file
  link(rel='stylesheet' href='Public/CSS/adminReports.css')
//
  =========================
  SIDE NAVIGATION BAR
  Contains links to all system pages
  =========================
nav.top-navbar
  // System title/logo
  .nav-logo
    h2 ParkVille
  // Navigation links
  ul.nav-links
    // Admin Revenue Reports page
    li
      a(href='reports.html') Reports
    // Register vehicles page
    li
      a(href='register.html') Register
    // Parking attendants page
    li
      a(href='attendants.html') Attendants
    // Vehicle sign out page
    li
      a(href='signout.html') Sign Out
    // Battery hire services
    li
      a(href='battery.html') Battery
    // Tyre services page
    li
      a(href='tyre.html') Tyre
//
  =========================
  MAIN DASHBOARD CONTAINER
  Wraps the entire page content
  =========================
.container
  //
    =========================
    HEADER SECTION
    Logo + action buttons
    =========================
  header.header
    // Left side logo/title
    .logo
      img(src='Assests/logo-P.png' alt='parkease-logo' width='100')
      h2 PARKVILLE DAILY REPORTS
    // Right side buttons
    .header-buttons
      button.btn.yellow Download PDF
      button.btn Export CSV
  //
    =========================
    REVENUE OVERVIEW SECTION
    Shows the 3 revenue cards
    =========================
  section.revenue-overview
    h3 Revenue Overview
    // Revenue cards container
    .cards
      // Parking revenue card
      .card
        p.card-title PARKING REVENUE
        img(src='Assests/cash.jpg' alt='money picture' width='150')
        h2 UGX 4,600,000
        span.increase &#x25B2; +12.5%
      // Tyre clinic card
      .card
        p.card-title TYRE HIRE
        img(src='Assests/yellowtyre.PNG' alt='a tyre' width='150')
        h2 UGX 1,650,000
        span.increase &#x25B2; +5.2%
      // Battery hire card
      .card
        p.card-title BATTERY HIRE
        img(src='Assests/yellow-bluebattery.PNG' alt='a type of battery' width='150')
        h2 UGX 720,000
        span.increase &#x25B2; +2.1%
  //
    =========================
    REPORT DAY SELECTOR
    =========================
  .date-selector
    button.arrow &#x25C0;
    span March 25, 2026
    button.arrow &#x25B6;
  //
    =========================
    VEHICLE TABLE SECTION
    =========================
  section.table-section
    // Table title + search
    .table-header
      h3 All Signed-out Vehicles
      // Search box
      input(type='text' placeholder='Search plates...')
    //
      =========================
      TABLE
      =========================
    table
      // Table headings
      thead
        tr
          th RECEIPT #
          th PLATE #
          th IN-TIME
          th OUT-TIME
          th DURATION
          th FEE
      // Table data
      tbody
        tr
          td #PE-98231
          td UAA 214A
          td 08:15 AM
          td 05:30 PM
          td 9h 15m
          td UGX 25,000
        tr
          td #PE-98232
          td UBB 673B
          td 09:00 AM
          td 02:15 PM
          td 5h 15m
          td UGX 15,000
        tr
          td #PE-98233
          td UAX 982X
          td 10:30 AM
          td 06:45 PM
          td 8h 15m
          td UGX 22,000
        tr
          td #PE-98234
          td UAW 119W
          td 07:45 AM
          td 11:00 AM
          td 3h 15m
          td UGX 10,000
        tr
          td #PE-98235
          td UAZ 541Z
          td 11:15 AM
          td 08:00 PM
          td 8h 45m
          td UGX 24,000
    //
      =========================
      TABLE FOOTER (TOTAL)
      =========================
    .table-footer
      span DAILY GRAND TOTAL :
      h2 UGX 6,790,000
  //
    =========================
    FOOTER
    =========================
  footer.footer
    h2 ADMIN CONTROL PANEL
    p &copy; 2026 ParkVille Smart Systems
