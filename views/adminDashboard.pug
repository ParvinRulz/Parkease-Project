extends layout

block content
  .container.py-5

    // HEADER + FILTER
    .d-flex.justify-content-between.align-items-center.mb-4.flex-wrap.gap-3.border-bottom.pb-3
      .d-flex.flex-column
        h2.fw-bold.mb-1 System Admin Dashboard
        p.text-muted.mb-0 Daily Revenue & Vehicle Sign-Out Report

      form.d-flex.align-items-center(action="/adminDashboard" method="GET")
        label.me-2.fw-semibold(for="dateFilter") Filter by Day:
        input.form-control.me-2#dateFilter(type="date" name="date" value=selectedDate)
        button.btn.btn-warning(type="submit")
          i.fa-solid.fa-filter.me-1
          | Filter

    // REVENUE CARDS
    .row.g-4.mb-5

      // PARKING
      .col-md-4
        .card.shadow-sm.border-0.rounded-4.h-100(style="background-color:#0f172a; color:white;")
          .card-body.p-4
            .d-flex.justify-content-between.align-items-center.mb-3
              h6.fw-bold.text-white-50.mb-0 PARKING REVENUE
              i.fa-solid.fa-square-parking.fs-3.text-white-50
              //- h3.fw-bold UGX #{parkingRevenue.toLocaleString()}
              p.small.mb-0 Total parking fees collected today

      // TYRE
      .col-md-4
        .card.shadow-sm.border-0.rounded-4.h-100.bg-success.text-white
          .card-body.p-4
            .d-flex.justify-content-between.align-items-center.mb-3
              h6.fw-bold.text-white-50.mb-0 TYRE CLINIC REVENUE
              i.fa-solid.fa-circle-notch.fs-3.text-white-50
              //- h3.fw-bold UGX #{tyreRevenue.toLocaleString()}
              p.small.mb-0 Total tyre services & sales today

      // BATTERY
      .col-md-4
        .card.shadow-sm.border-0.rounded-4.h-100.bg-warning.text-dark
          .card-body.p-4
            .d-flex.justify-content-between.align-items-center.mb-3
              h6.fw-bold.text-dark-50.mb-0 BATTERY REVENUE
              i.fa-solid.fa-car-battery.fs-3.text-dark-50
              //- h3.fw-bold UGX #{batteryRevenue.toLocaleString()}
              p.small.mb-0 Total battery hire & sales today


    // TABLE SECTION
    .card.shadow-sm.border-0.rounded-4
      .card-header.bg-white.py-3.border-bottom
        h5.mb-0.fw-bold
          i.fa-solid.fa-car-side.me-2(style="color:#0f172a;")
          | Signed-Out Vehicles for #{selectedDate}

      .card-body.p-0

        .table-responsive
          table.table.table-hover.align-middle.mb-0
            thead(style="background-color:#f8fafc;")
              tr
                th.px-4 Receipt No.
                th Receiver Name
                th Vehicle Plate
                th Sign-Out Time
                th Amount Paid

            tbody
              if signedOutVehicles && signedOutVehicles.length > 0
                each record in signedOutVehicles
                  tr
                    td.px-4.fw-semibold(style="color:#0f172a;")= record.receiptNumber
                    td= record.receiverName

                    td
                      if record.vehicleId
                        span.badge(style="background-color:#0f172a;")= record.vehicleId.numberPlate
                      else
                        span.text-muted N/A

                    td= new Date(record.signoutDate).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})

                    td.fw-bold.text-success UGX #{record.amountPaid.toLocaleString()}

              else
                tr
                  td.text-center.py-5.text-muted(colspan="5")
                    i.fa-solid.fa-folder-open.fs-1.mb-3.d-block.text-light
                    | No vehicles were signed out on this date.