doctype html
html(lang='en')
  head
    meta(charset='utf-8')
    meta(name='viewport' content='width=device-width, initial-scale=1')
    title System Admin Dashboard
    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css' rel='stylesheet')

    style.
      .dark-blue {
        background-color: #0f172a !important;
      }
      .dark-blue a,
      .dark-blue .navbar-brand,
      .dark-blue p {
        color: #fff !important;
      }
      .dark-text {
        color: #0f172a;
      }
      .card-soft {
        border: none;
        border-radius: 16px;
        box-shadow: 0 6px 18px rgba(0,0,0,0.08);
      }
      .yellow-bg {
        background-color: #facc15;
      }

  body.d-flex.flex-column.min-vh-100

    // NAVBAR
    nav.navbar.navbar-expand-lg.dark-blue
      .container
        a.navbar-brand.fw-bold(href='#') System Admin Dashboard

    // MAIN CONTENT
    .container.py-5.flex-grow-1

      // HEADER + FILTER
      .d-flex.justify-content-between.align-items-center.mb-4.flex-wrap.gap-3.border-bottom.pb-3
        .d-flex.flex-column
          h2.fw-bold.mb-1.dark-text System Admin Dashboard
          p.text-muted.mb-0 Daily Revenue & Oversight Management Report

        form.d-flex.align-items-center(action="/adminDashboard" method="GET")
          label.me-2.fw-semibold(for="dateFilter") Filter by Day:
          input.form-control.me-2#dateFilter(type="date" name="date" value=selectedDate)
          button.btn.yellow-bg.fw-semibold(type="submit") Filter

      // REVENUE CARDS
      .row.g-4.mb-5

        .col-md-4
          .card.card-soft.text-white(style="background:#0f172a;")
            .card-body.p-4
              h6.text-white-50.fw-semibold PARKING REVENUE
              h3.fw-bold.mt-2 UGX #{parkingRevenue ? parkingRevenue.toLocaleString() : 0}
              p.text-white-50.small.mb-0 Total parking fees collected today

        .col-md-4
          .card.card-soft.bg-white
            .card-body.p-4
              h6.text-muted.fw-semibold TYRE CLINIC REVENUE
              h3.fw-bold.dark-text.mt-2 UGX #{tyreRevenue ? tyreRevenue.toLocaleString() : 0}
              p.text-muted.small.mb-0 Total tyre services & sales today

        .col-md-4
          .card.card-soft.yellow-bg
            .card-body.p-4
              h6.fw-semibold BATTERY REVENUE
              h3.fw-bold.mt-2 UGX #{batteryRevenue ? batteryRevenue.toLocaleString() : 0}
              p.small.mb-0 Total battery hire & sales today

      // USERS TABLE
      .card.card-soft
        .card-header.bg-white.py-3.border-bottom
          h5.mb-0.fw-bold.dark-text Signed-In Users

        .card-body.p-0
          .table-responsive
            table.table.table-hover.mb-0.align-middle
              thead(style="background:#f8fafc;")
                tr
                  th.p-3 Image
                  th Name
                  th Role

              tbody
                each user in users
                  tr
                    td.p-3
                      if user.image
                        img.rounded(src='/' + user.image alt='User image' width='80' height='70')
                      else
                        span.text-muted No image
                    td.fw-semibold.dark-text= user.name
                    td= user.role

    // FOOTER (STICKS TO BOTTOM)
    footer.footer.dark-blue.text-center.p-3.mt-auto
      p SYSTEM ADMIN CONTROL PANEL
      p © 2026 Parvin 2026 ParkVille Smart Systems

    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js')