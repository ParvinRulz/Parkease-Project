doctype html
html(lang='en')
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1')
    title SignUp 

    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')

    style.
      body {
        background: linear-gradient(to right, #f8fafc, #e2e8f0);
      }

      .dark-blue {
        color: #0f172a;
      }

      .link-yellow {
        color: #ffc107 !important;
        text-decoration: none;
      }

      .login-card {
        border-radius: 20px;
      }

      .form-control, .form-select {
        border-radius: 10px;
        padding: 10px;
      }

      .form-control:focus, .form-select:focus {
        box-shadow: 0 0 0 2px rgba(255,193,7,0.3);
        border-color: #ffc107;
      }

      .btn-warning {
        background-color: #ffc107 !important;
        border: none;
        color: #0f172a;
      }

      .btn-warning:hover {
        background-color: #e0a800 !important;
      }

  body
    // ================= NAVBAR =================
    nav.navbar.navbar-expand-lg.bg-white.shadow-sm
      .container-fluid

        a.navbar-brand.fw-bold(style='color:#0f172a;' href='/login') ParkVille

        button.navbar-toggler(type='button' data-bs-toggle='collapse' data-bs-target='#navbarNav')
          span.navbar-toggler-icon

        #navbarNav.collapse.navbar-collapse
          ul.navbar-nav.me-auto.mb-2.mb-lg-0
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/signup") Signup
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/login") Login
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/login") Dashboard
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/users") Manage Users
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/registerVehicle") Vehicle
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/signout") Vehicle Signout
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/battery") Battery Services
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/tyre") Tyre Clinic

    .container.min-vh-100.d-flex.align-items-center.justify-content-center

      .row.shadow-lg.bg-white.overflow-hidden(style='max-width: 850px; width:100%; border-radius:20px;')

        // LEFT SIDE
        .col-md-5.d-none.d-md-flex.flex-column.justify-content-center.align-items-center.text-center.p-4(style='background-color:#0f172a; color:white;')
          img(src='/Images/logo.png' style='width:70px;')
          h4.mt-3.fw-bold ParkVille
          p.small.mt-2
            | Integrated Parking & Vehicle Services Management System offering Tyre Clinic & Battery Hire Services with efficiency and security.

        // RIGHT SIDE
        .col-md-7.p-4.p-md-5

          .text-center.mb-4
            h4.fw-bold.dark-blue Create An Account

          form(action="/signup" method="POST")

            .row.mb-3
              .col-md-6.mb-3.mb-md-0
                label.form-label.fw-semibold(for='firstName') First Name
                input#firstName.form-control(type='text' placeholder='Andrew' name='firstName')

              .col-md-6
                label.form-label.fw-semibold(for='lastName') Last Name
                input#lastName.form-control(type='text' placeholder='Semyalo' name='lastName')

            .mb-3
              label.form-label.fw-semibold(for='email') Email Address
              input#email.form-control(type='email' placeholder='name@example.com' name='email')

            .mb-3
              label.form-label.fw-semibold(for='phone') Phone Number
              input#phone.form-control(type='tel' placeholder='0700000000' name='phoneNumber')

            .mb-3
              label.form-label.fw-semibold(for='role') Role
              select#role.form-select(name='role')
                option(value='') Select role
                option(value='System Admin') System Admin
                option(value='Section Manager') Section Manager
                option(value='Parking Attendant') Parking Attendant

            .mb-4
              label.form-label.fw-semibold(for='password') Password
              input#password.form-control(type='password' placeholder='••••••••' name='password')
              .form-text Must be at least 8 characters long.

            // BUTTON (YELLOW)
            button.btn.btn-warning.w-100.py-2.fw-bold.rounded-3(type='submit') Sign Up

            // LOGIN LINK (separate from button)
            .text-center.mt-4
              p.mb-0.text-muted
                | Already have an account? 
                a.link-yellow(href='/login') Login

    // FOOTER
    footer.text-center.py-3.mt-4(style='position:absolute; bottom:10px; width:100%; color:#0f172a;')
      small © Parvin 2026 ParkVille System

    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')