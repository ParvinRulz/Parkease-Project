doctype html
html(lang='en')
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title Sign Up

    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')

    style.
      body {
        background-color: #f4f7f6;
      }

      .dark-blue {
        background-color: #0d1b2a !important;
        color: #fff !important;
      }

      .navbar .nav-link {
        color: #fff !important;
      }

      .navbar .nav-link.active {
        font-weight: bold;
      }

      .btn-primary {
        background-color: #ffc107 !important;
        border-color: #ffc107 !important;
        color: #000 !important;
      }

      .btn-primary:hover {
        background-color: #e0a800 !important;
        border-color: #e0a800 !important;
      }

      a {
        color: #ffc107 !important;
      }

  body
    // NAVBAR (Dark Blue + No Dropdown)
    nav.navbar.navbar-expand-lg.dark-blue
      .container-fluid
        a.navbar-brand.text-white(href='#') ParkVille

        button.navbar-toggler(
          type='button'
          data-bs-toggle='collapse'
          data-bs-target='#navbarNav'
        )
          span.navbar-toggler-icon

        #navbarNav.collapse.navbar-collapse
          ul.navbar-nav.me-auto
            li.nav-item
              a.nav-link.active(href='#') Home
            li.nav-item
              a.nav-link(href='#') Battery
            li.nav-item
              a.nav-link(href='#') Tyre
            li.nav-item
              a.nav-link(href='#') Other

    // MAIN FORM
    .container.min-vh-100.d-flex.justify-content-center.align-items-center
      .card.shadow-lg.border-0.rounded-4(style='width: 100%; max-width: 500px')
        .card-body.p-5
          h2.text-center.fw-bold.mb-4 Create an Account

          form(method='post' action='/signup')
            .row.mb-3
              .col-md-6.mb-3.mb-md-0
                label.form-label.fw-semibold(for='firstName') First Name
                input#firstName.form-control(type='text' placeholder='John' name='firstName')

              .col-md-6
                label.form-label.fw-semibold(for='lastName') Last Name
                input#lastName.form-control(type='text' placeholder='Doe' name='lastName')

            .mb-3
              label.form-label.fw-semibold(for='email') Email Address
              input#email.form-control(type='email' placeholder='name@example.com' name='email')

            .mb-3
              label.form-label.fw-semibold(for='phone') Phone Number
              input#phone.form-control(type='tel' placeholder='+256 700 000000' name='phoneNumber')

            .mb-3
              label.form-label.fw-semibold(for='role') Role
              select#role.form-select(name='role')
                option(value='') Select role
                option(value='System Admin') System Admin
                option(value='Section Manager') Section Manager
                option(value='Parking Attendant') Parking Attendant

            .mb-4
              label.form-label.fw-semibold(for='password') Password
              input#password.form-control(type='password' placeholder='••••••••' name='password')
              .form-text Must be at least 8 characters long.

            button.btn.btn-primary.w-100.py-2.fw-bold.rounded-3(type='submit') Sign Up

            .text-center.mt-4
              p.mb-0.text-muted
                | Already have an account?
                a.text-decoration-none(href='#') Log in

    // Bootstrap JS
    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')