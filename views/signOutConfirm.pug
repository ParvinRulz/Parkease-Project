extends layout

block content
  .container.min-vh-100.d-flex.justify-content-center.align-items-center
    .card.shadow-lg.border-0.rounded-4(style='width: 100%; max-width: 550px;')
      .card-body.p-5

        // TITLE
        h4.text-center.fw-bold.mb-4 Fee Calculation and SignOut

        // VEHICLE DETAILS
        .mb-4
          p.mb-2
            span.fw-bold Vehicle:
            |  #{car.vehicleType} (#{car.numberPlate})
          p.mb-2
            span.fw-bold Arrival Time:
            |  #{new Date(car.arrivalTime).toLocaleString()}
          p.mb-0
            span.fw-bold.fs-5(style='color:#ffc107;') Amount Due:
            |  
            span.fw-bold.fs-5(style='color:#ffc107;') UGX #{fee.toLocaleString()}

        // SUBTITLE
        h5.text-center.fw-bold.mb-4 Confirm SignOut

        // FORM
        form(method='post' action='/signout/confirm')
          input(type='hidden' name='receiptNumber' value=car.receiptNumber)
          input(type='hidden' name='vehicleId' value=car._id)
          input(type='hidden' name='amountPaid' value=fee)

          .row.mb-3
            .col-md-6
              label.form-label.fw-semibold(for='receiverName') Receiver Name
              input#receiverName.form-control(type='text' placeholder='John' name='receiverName')

          .mb-3
            label.form-label.fw-semibold(for='phone') Phone Number
            input#phone.form-control(type='tel' placeholder='+256 700 000000' name='phoneNumber')

          .mb-3
            label.form-label.fw-semibold(for='gender') Gender
            select#gender.form-select(name="gender")
              option(value="") Select Gender
              option(value="Male") Male
              option(value="Female") Female

          .mb-4
            label.form-label.fw-semibold(for='ninNumber') NIN Number
            input#ninNumber.form-control(type='text' placeholder='••••••••' name='ninNumber')

          // BUTTON (YELLOW)
          button.btn.w-100.py-2.fw-bold.rounded-3(
            type='submit'
            style='background-color:#ffc107; border:none;'
          ) Confirm SignOut

    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')