doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1')
    title Parking Attendant Dashboard

    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')

    style.
      .dark-nav {
        background-color: #0f172a !important;
      }

      .card-soft {
        border: none;
        border-radius: 16px;
        box-shadow: 0 6px 18px rgba(0,0,0,0.08);
      }

      .btn-dark-custom {
        background-color: #0f172a;
        color: #fff;
      }

      .btn-dark-custom:hover {
        background-color: #020617;
        color: #fff;
      }

  body.d-flex.flex-column.min-vh-100
    // ================= NAVBAR =================
    nav.navbar.navbar-expand-lg.bg-white.shadow-sm
      .container-fluid

        a.navbar-brand.fw-bold(style='color:#0f172a;' href='/login') ParkVille

        button.navbar-toggler(type='button' data-bs-toggle='collapse' data-bs-target='#navbarNav')
          span.navbar-toggler-icon

        #navbarNav.collapse.navbar-collapse
          ul.navbar-nav.me-auto.mb-2.mb-lg-0
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/signup") Signup
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/login") Login
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/login") Dashboard
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/users") Manage Users
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/registerVehicle") Vehicle
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/signout") Vehicle Signout
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/battery") Battery Services
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/tyre") Tyre Clinic

    
    // MAIN CONTENT
    .container.py-4.flex-grow-1

      // HEADER
      .d-flex.justify-content-between.align-items-center.mb-4.flex-wrap.gap-2
        h4.fw-bold.mb-0 Parking Attendant Dashboard
        span.text-muted SHIFT: 06:00 AM - 06:59 PM

      // SUMMARY CARDS
      .row.g-4.mb-4

        .col-md-3
          .card.card-soft.p-3.text-center
            h6.text-muted Registered Today
            h3.fw-bold= activity[0].registeredToday || 0

        .col-md-3
          .card.card-soft.p-3.text-center
            h6.text-muted Vehicles Parked
            h3.fw-bold= activity[0].vehiclesParked || 0

        .col-md-3
          .card.card-soft.p-3.text-center
            h6.text-muted Signed Out Today
            h3.fw-bold= activity[0].signedOutToday || 0

        .col-md-3
          .card.card-soft.p-3.text-center
            h6.text-muted Revenue Today
            h3.fw-bold= activity[0].revenueToday || 0

      // QUICK ACTIONS
      .mb-4
        h5.mb-3 Quick Actions
        .row.g-3
          .col-md-4
            a.btn.btn-dark-custom.w-100(href='/registerVehicle') Register Vehicle
          .col-md-4
            a.btn.btn-warning.w-100(href='/signout') Sign Out Vehicle
          .col-md-4
            a.btn.btn-secondary.w-100(href='/receipt/print') Print Receipt

      // RECENT ACTIVITY
      .card.card-soft
        .card-body
          h5.mb-3 Recent Activity

          .table-responsive
            table.table.table-hover.align-middle
              thead.table-light
                tr
                  th Plate
                  th Driver
                  th Action
                  th Time

              tbody
                if recentActivity && recentActivity.length > 0
                  each recent in recentActivity
                    tr
                      td.fw-semibold= recent.plate
                      td= recent.driver

                      td= recent.action
                        

                      td= recent.arrivalTime
                else
                  tr
                    td.text-center.text-muted(colspan='4') No activity found

    // FOOTER
    footer.dark-nav.text-white.text-center.py-3.mt-auto
      p PARKING ATTENDANT CONTROL PANEL
      small © Parvin 2026 ParkVille Smart Systems

    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')