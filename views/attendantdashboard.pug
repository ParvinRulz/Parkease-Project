doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1')
  title ParkVille Attendant Dashboard
  // Bootstrap CSS
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')
// NAVBAR
nav.navbar.navbar-expand-lg.navbar-dark.bg-dark.px-4
  a.navbar-brand.fw-bold(href='#') ParkVille
  button.navbar-toggler(type='button' data-bs-toggle='collapse' data-bs-target='#navMenu')
    span.navbar-toggler-icon
  #navMenu.collapse.navbar-collapse
    ul.navbar-nav.ms-auto
      li.nav-item
        a.nav-link(href='#') Reports
      li.nav-item
        a.nav-link(href='#') Register
      li.nav-item
        a.nav-link(href='#') Attendants
      li.nav-item
        a.nav-link(href='#') Sign Out
      li.nav-item
        a.nav-link(href='#') Battery
      li.nav-item
        a.nav-link(href='#') Tyre
// MAIN
.container.py-4
  // TOP BAR
  .d-flex.justify-content-between.align-items-center.mb-4
    input.form-control.w-50(type='text' placeholder='Search vehicle, receipt or plate number...')
    .fw-semibold
      | &#x23F0; SHIFT: 08:00 AM - 04:00 PM
  // CARDS
  .row.g-4.mb-4
    .col-md-4
      .card.shadow-sm.text-center.p-3
        p.text-muted TOTAL VEHICLES PARKED
        img.img-fluid.mb-2(src='/Assests/car.jpeg' style='max-height:120px;')
        h3 122
        span.text-success +12% Today
    .col-md-4
      .card.shadow-sm.text-center.p-3
        p.text-muted TODAY&apos;S TOTAL REVENUE
        img.img-fluid.mb-2(src='/Assests/money.jpg' style='max-height:120px;')
        h3 UGX 8,000,000
        span.text-primary Daily Goal: 80%
    .col-md-4
      .card.shadow-sm.text-center.p-3
        p.text-muted AVAILABLE PARKING SLOTS
        img.img-fluid.mb-2(src='/Assests/parkinglot.jpg' style='max-height:120px;')
        h3 28 / 150
        .progress.mt-2
          .progress-bar(style='width:81%')
        .d-flex.justify-content-between.mt-2
          small 81% Occupied
          small High Demand
  // ACTION BUTTONS
  .mb-4
    h4.mb-3 Quick Actions
    .d-flex.gap-3.flex-wrap
      button.btn.btn-warning &#x279C; Register Arrival
      button.btn.btn-dark &#x2B05; Vehicle Sign-out
      button.btn.btn-secondary &#x1F5A8; Print Daily Summary
  // TABLE
  .table-container
    thead
      tr
        th(scope='col') Vehicle Image
        th(scope='col') Driver Name
        th(scope='col') Phone Number
        th(scope='col') Vehicle Type
        th(scope='col') Plate Number
        th(scope='col') Vehicle Model
        th(scope='col') Vehicle Color
        th(scope='col') Arrival Date
        th(scope='col') Arrival Time
        th(scope='col') Status
          th(scope='col') Update
          th(scope='col') Delete
          th(scope='col') Action
        
    tbody
      if cars.length
        each car in cars
          tr
            td 
              img(src="/"+car.vehicleImage alt="Vehicle image" width="150px", height="170px")
            td #{car.driverName}
            td #{car.phoneNumber}
            td #{car.vehicleType}
            td #{car.numberPlate}
            td #{car.vehicleModel}
            td #{car.vehicleColor}
            td #{car.arrivalDate}
            td #{car.arrivalTime}
            td #{car.status}
            td #{car.receiptNumber}
            td
                button.btn.btn-sm.btn-outline-primary(onclick=`navigator.clipboard.writeText(`${vehicle.receiptNumber}`); alert("Receipt ${vehicle.receiptNumber} copied");`)
                  i.fa-solid.fa-copy.me-1
                  |Copy
      else
          tr
            td.text-center.py-4.text-muted(colspan="4") No cars found.
      
      
// FOOTER
footer.bg-dark.text-white.text-center.py-3.mt-4
  h6.mb-1 PARKING ATTTENDANT CONTROL PANEL
  small &copy; 2026 ParkVille Smart Systems
// Bootstrap JS
script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')
