doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1')
    title Parking Attendant Dashboard

    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')

    style.
      .dark-nav {
        background-color: #0f172a !important;
      }

      .card-soft {
        border: none;
        border-radius: 16px;
        box-shadow: 0 6px 18px rgba(0,0,0,0.08);
      }

      .btn-dark-custom {
        background-color: #0f172a;
        color: #fff;
      }

      .btn-dark-custom:hover {
        background-color: #020617;
        color: #fff;
      }

  body.d-flex.flex-column.min-vh-100

    // NAVBAR
    nav.navbar.navbar-expand-lg.navbar-dark.dark-nav.px-4
      a.navbar-brand.fw-bold(href='/attendant') ParkVille

      button.navbar-toggler(type='button' data-bs-toggle='collapse' data-bs-target='#navMenu')
        span.navbar-toggler-icon

      #navMenu.collapse.navbar-collapse
        ul.navbar-nav.ms-auto
          li.nav-item
            a.nav-link(href='/attendant') Dashboard
          li.nav-item
            a.nav-link(href='/registerVehicle') Register
          li.nav-item
            a.nav-link(href='/signout') Sign Out

    // MAIN CONTENT
    .container.py-4.flex-grow-1

      // HEADER
      .d-flex.justify-content-between.align-items-center.mb-4.flex-wrap.gap-2
        h4.fw-bold.mb-0 Parking Attendant Dashboard
        span.text-muted SHIFT: 06:00 AM - 06:59 PM

      // SUMMARY CARDS
      .row.g-4.mb-4

        .col-md-3
          .card.card-soft.p-3.text-center
            h6.text-muted Registered Today
            h3.fw-bold= todayRegistrationsCount || 0

        .col-md-3
          .card.card-soft.p-3.text-center
            h6.text-muted Vehicles Parked
            h3.fw-bold= parkedVehicles || 0

        .col-md-3
          .card.card-soft.p-3.text-center
            h6.text-muted Signed Out Today
            h3.fw-bold= signedOutCount || 0

        .col-md-3
          .card.card-soft.p-3.text-center
            h6.text-muted Revenue Today
            h3.fw-bold UGX #{todayRevenue ? todayRevenue.toLocaleString() : 0}

      // QUICK ACTIONS
      .mb-4
        h5.mb-3 Quick Actions
        .row.g-3
          .col-md-4
            a.btn.btn-dark-custom.w-100(href='/registerVehicle') Register Vehicle
          .col-md-4
            a.btn.btn-warning.w-100(href='/signout') Sign Out Vehicle
          .col-md-4
            a.btn.btn-secondary.w-100(href='/receipt/print') Print Receipt

      // RECENT ACTIVITY
      .card.card-soft
        .card-body
          h5.mb-3 Recent Activity

          .table-responsive
            table.table.table-hover.align-middle
              thead.table-light
                tr
                  th Plate
                  th Driver
                  th Action
                  th Time

              tbody
                if recentCars && recentCars.length > 0
                  each car in recentCars
                    tr
                      td.fw-semibold= car.numberPlate
                      td= car.driverName

                      td
                        if car.status === 'In'
                          span.badge.bg-success Arrived
                        else if car.status === 'Out'
                          span.badge.bg-secondary Signed Out
                        else
                          span.badge.bg-warning Pending

                      td= car.arrivalTime
                else
                  tr
                    td.text-center.text-muted(colspan='4') No activity found

    // FOOTER
    footer.dark-nav.text-white.text-center.py-3.mt-auto
      p PARKING ATTENDANT CONTROL PANEL
      small © Parvin 2026 ParkVille Smart Systems

    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')