doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title ParkVille Battery Hire
  // Bootstrap CSS
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')
// Navbar
nav.navbar.navbar-expand-lg.navbar-light.bg-light.px-3
  a.navbar-brand(href='#')
    h2 ParkVille
  button.navbar-toggler(type='button' data-bs-toggle='collapse' data-bs-target='#navbarNav')
    span.navbar-toggler-icon
  #navbarNav.collapse.navbar-collapse
    ul.navbar-nav.me-auto
      li.nav-item
        a.nav-link(href='reports.html') Reports
      li.nav-item
        a.nav-link(href='attendantdashboard.html') Attendant
      li.nav-item
        a.nav-link(href='register.html') Register
      li.nav-item
        a.nav-link.active(href='battery.html') Battery
      li.nav-item
        a.nav-link(href='tyre-hire.html') Tyre-hire
      li.nav-item
        a.nav-link(href='signout.html') Signout
      li.nav-item
        a.nav-link(href='login.html') Logout
    form.d-flex
      input.form-control.me-2(type='search' placeholder='Search batteries...')
      button.btn.btn-outline-primary(type='submit') Sign In
    .ms-3.badge.bg-secondary.p-2.rounded-circle 1
// Hero Section
section.container.my-5
  .row.align-items-center
    .col-lg-6
      span.badge.bg-warning.text-dark.mb-2 INDUSTRIAL GRADE
      h1
        | Heavy-Duty 
        br
        span Industrial
        br
        |             Battery Hire
      p.text-muted
        | Reliable power solutions for every vehicle type. High-capacity,
        | long-lasting 3-phase and lead-acid batteries ready for immediate
        | deployment across Uganda.
      .d-flex.gap-2
        button.btn.btn-warning View Inventory
        button.btn.btn-outline-dark Get a Quote
    .col-lg-6.text-center
      img.img-fluid(src='Assests/battery1.PNG' alt='Battery Hero')
// Browse Section
section.container.my-5
  .d-flex.justify-content-between.align-items-center.mb-3
    h2 Browse Selection
    .btn-group
      button.btn.btn-primary.active All Categories
      button.btn.btn-outline-primary Traction
      button.btn.btn-outline-primary Emergency
  .row.g-4
    // Product 1
    .col-md-4
      .card.h-100.text-center.shadow-sm
        img.card-img-top(src='Assests/battery2.png' alt='UltraVolt X1000')
        .card-body
          h5.card-title UltraVolt X1000
          p.card-text 48V 100Ah &ndash; Industrial Grade
          span.badge.bg-success.mb-2 In Stock
          h4 UGX 170,000/day
          button.btn.btn-warning.mt-2 Book Now
    // Product 2
    .col-md-4
      .card.h-100.text-center.shadow-sm
        img.card-img-top(src='Assests/battery3.PNG' alt='IronCore Heavy Duty')
        .card-body
          h5.card-title IronCore Heavy Duty
          p.card-text 24V / 400Ah &ndash; Rugged Use
          span.badge.bg-warning.mb-2 Low Stock
          h4 UGX 190,000
          button.btn.btn-warning.mt-2 Book Now
    // Product 3
    .col-md-4
      .card.h-100.text-center.shadow-sm
        img.card-img-top(src='Assests/battery4.PNG' alt='GigaCell 120Ah')
        .card-body
          h5.card-title GigaCell 120Ah
          p.card-text 12V 120Ah &ndash; Multi Purpose
          span.badge.bg-danger.mb-2 Offer
          h4 UGX 55,000
          button.btn.btn-warning.mt-2 Book Now
// CTA
section.container.text-center.my-5
  h2 Need a Custom Fleet Solution?
  p.text-muted.mb-3
    | We offer discounted rates for long-term rentals and bulk sales for
    | industrial logistics partners across the region.
  button.btn.btn-warning Contact Sales Team
// Footer
footer.bg-light.mt-5.pt-4.pb-3
  .container
    .row.mb-3
      .col-md-4
        h5 ParkVille
        p.text-muted
          | Powering your performance with premium battery solutions. Dedicated to keeping Uganda&rsquo;s wheels moving.
      .col-md-4
        h6 SERVICES
        p Short Term Hire
        p Long Term Leasing
        p Battery Maintenance
        p Fleet Management
      .col-md-4
        h6 VEHICLE TYPES
        p UPS Systems
    .d-flex.justify-content-between.border-top.pt-3
      p.mb-0 &copy; 2026 ParkVille Smart Systems Ltd. All rights reserved.
      div
        a.me-2(href='#') Privacy Policy
        a.me-2(href='#') Terms of Service
        a(href='#') Cookies
// Bootstrap JS
script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')
