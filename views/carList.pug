doctype html
html(lang='en')
  head
    meta(charset='UTF-8')
    meta(name='viewport', content='width=device-width, initial-scale=1.0')
    title Car Page

    // Bootstrap & Icons
    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css', rel='stylesheet')
    link(href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css', rel='stylesheet')

    style.
      body {
        background-color: #f8fafc;
      }

      .custom-navbar,
      .custom-footer {
        background-color: #0f172a !important;
      }

      .custom-navbar .nav-link,
      .custom-navbar .navbar-brand {
        color: #fff !important;
      }

      .custom-navbar .nav-link.active {
        font-weight: bold;
      }

      .card {
        border-radius: 12px;
      }

  body.d-flex.flex-column.min-vh-100

    // ================= NAVBAR =================
    nav.navbar.navbar-expand-lg.bg-white.shadow-sm
      .container-fluid

        a.navbar-brand.fw-bold(style='color:#0f172a;' href='/login') ParkVille

        button.navbar-toggler(type='button' data-bs-toggle='collapse' data-bs-target='#navbarNav')
          span.navbar-toggler-icon

        #navbarNav.collapse.navbar-collapse
          ul.navbar-nav.me-auto.mb-2.mb-lg-0
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/signup") Signup
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/login") Login
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/login") Dashboard
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/users") Manage Users
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/registerVehicle") Vehicle
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/signout") Vehicle Signout
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/battery") Battery Services
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/tyre") Tyre Clinic
    // MAIN CONTENT
    main.container.mt-5.flex-grow-1

      // DASHBOARD CARD
      .row.mb-4
        .col-md-4
          .card.shadow-sm.p-4.text-center
            h5.mb-2 CARS PARKED
            img(src='/Images/parkinglot.jpg', style='width:150px;')

      // TABLE SECTION
      .card.shadow-sm
        .card-body
          .table-responsive
            table.table.table-hover.align-middle
              thead.table-light
                tr
                  th Vehicle Image
                  th Driver Name
                  th Phone Number
                  th Vehicle Type
                  th Plate Number
                  th Vehicle Model
                  th Vehicle Color
                  th Arrival Date
                  th Arrival Time
                  th Status
                  th Update
                  th Delete
              tbody
                if cars.length
                  each car in cars
                    tr
                      td
                        img.rounded(src='/' + car.vehicleImage, alt='Vehicle image', width='120', height='100')
                      td #{car.driverName}
                      td #{car.phoneNumber}
                      td #{car.vehicleType}
                      td #{car.numberPlate}
                      td #{car.vehicleModel}
                      td #{car.vehicleColor}
                      td #{car.arrivalDate}
                      td #{car.arrivalTime}
                      td #{car.status}
                      td
                        a.btn.btn-sm.btn-outline-warning.text-dark(href=`/vehicles/update/${car._id}`)
                          i.fa-solid.fa-pen-to-square
                      td
                        form(method='post', action='/vehicles/delete')
                          input(type='hidden', name='id', value=car._id)
                          button.btn.btn-sm.btn-outline-danger.text-dark(type='submit')
                            i.fa-solid.fa-trash
                else
                  tr
                    td.text-center.py-4.text-muted(colspan='12') No cars found.

    // FOOTER
    footer.custom-footer.text-white.text-center.py-3.mt-auto
      small © Parvin 2026 ParkVille System

    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js')