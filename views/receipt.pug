doctype html
html(lang='en')
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title Official ParkVille Receipt

    // Bootstrap CSS
    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')

    // Font Awesome
    link(href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css' rel='stylesheet')

    style.
      body {
        background: linear-gradient(to right, #f8fafc, #e2e8f0);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .receipt-wrapper {
        flex: 1;
      }

      .receipt-card {
        max-width: 480px;
        width: 100%;
      }

      .divider {
        border-top: 1px dashed #cbd5e1;
        margin: 15px 0;
      }

      .no-print {
        display: block;
      }

      @media print {
        .no-print {
          display: none !important;
        }
      }

  body

    // MAIN CONTENT
    .receipt-wrapper.d-flex.justify-content-center.align-items-center
      .container
        .card.shadow-lg.border-0.rounded-4.receipt-card.mx-auto
          .card-body.p-5

            // Header
            h2.text-center.fw-bold.mb-1 ParkVille
            p.text-center.text-muted.mb-4 Integrated Parking System

            h5.text-center.fw-bold.text-uppercase.mb-3 Official Receipt
            p.text-center.font-monospace.mb-4= record.receiptNumber

            .divider

            // Transaction Details
            .mb-3
              .d-flex.justify-content-between
                span.text-muted Date
                span.fw-semibold= new Date(record.signoutTime).toLocaleDateString()

              .d-flex.justify-content-between
                span.text-muted Time Out
                span.fw-semibold= new Date(record.signoutTime).toLocaleTimeString([], {hour:"2-digit", minute:"2-digit"})

              .d-flex.justify-content-between
                span.text-muted Number Plate
                span.fw-semibold= record.vehicleId.numberPlate

              .d-flex.justify-content-between
                span.text-muted Vehicle Type
                span.fw-semibold= record.vehicleId.vehicleType

              .d-flex.justify-content-between
                span.text-muted Receiver
                span.fw-semibold= record.receiverName

            .divider

            // Financial Section
            .text-center
              p.text-muted.mb-1 Total Paid
              h3.fw-bold(style="color:#facc15;") UGX #{record.amountPaid.toLocaleString()}

            .divider

            // Footer Message
            .text-center.mt-3
              p.small.text-muted.mb-1 Thank you for using ParkVille!
              p.small.text-muted Drive Safely

          // Buttons
          .card-footer.bg-white.border-0.p-4.pt-0.no-print
            button.btn.w-100.py-2.fw-bold.mb-2(style="background-color: #facc15; border:none;" onclick="window.print()")
              i.fa-solid.fa-print.me-2
              | Print Receipt

            a.btn.w-100.fw-bold.text-white(href="/" style="background-color: #0f172a;")
              | Return Home

    // FOOTER 
    footer.text-center.py-3(style='color:#0f172a;')
      small © Parvin 2026 ParkVille System

    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')