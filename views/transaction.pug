extends layout
block content 
  .container.min-vh-100.d-flex.justify-content-center.align-items-center
    .card.shadow-lg.border-0.rounded-4(style='width: 100%; max-width: 450px;')
      .card-body.p-5
        h2.text-center.fw-bold.mb-2 Transactions
        p.text-center.text-muted.mb-4 Enter transaction details.
        form(method='post' action='/add-transaction')
           .mb-4
            label.form-label.fw-semibold(for='service') Service
            input#service.form-control(type='text' name='service' )
            label.form-label.fw-semibold(for='customer') Customer
            input#customer.form-control(type='text' name='customer' )
            label.form-label.fw-semibold(for='amount') Amount
            input#customer.form-control(type='text' name='amount' )
          button.btn.btn-primary.w-100.py-2.fw-bold.rounded-3(type='submit') Add Transaction
  script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')