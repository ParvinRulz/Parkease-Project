extends layout
block content 
  .container.min-vh-100.d-flex.justify-content-center.align-items-center
    .card.shadow-lg.border-0.rounded-4(style='width: 100%; max-width: 450px;')
      .card-body.p-5
        h2.text-center.fw-bold.mb-2 Batteries
        p.text-center.text-muted.mb-4 Please enter your details to sign in.
        form(method='post' action='/batteryServices')
          .mb-3
            
            label.form-label.fw-semibold(for='batteryId') Select Battery
            select#batteryId(name="batteryId")
              option(value="" selected disabled) Choose battery
              if availableBatteries && availableBatteries.length > 0
                each battery in availableBatteries
                    option(value=battery._id ) #{battery.batteryType} - #{battery.batterySize}
          .mb-4
            label.form-label.fw-semibold(for='transactionType') Transaction Type
            select#transactionType(name="transactionType")
              option(value="") Select Transaction
              option(value="Hire") Hire
              option(value="Sale") Sale
          .mb-4
            label.form-label.fw-semibold(for='numberPlate') Number Plate
            input#numberPlate.form-control(type='text' name='numberPlate' )
            label.form-label.fw-semibold(for='amountPaid') Amount paid
            input#amountPaid.form-control(type='number' name='amountPaid' )
          button.btn.btn-primary.w-100.py-2.fw-bold.rounded-3(type='submit') Add Battery
  script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')