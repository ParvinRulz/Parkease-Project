extends layout
block content 
  .container.min-vh-100.d-flex.justify-content-center.align-items-center
    .card.shadow-lg.border-0.rounded-4(style='width: 100%; max-width: 450px;')
      .card-body.p-5
        h2.text-center.fw-bold.mb-2 Recent Activity
        p.text-center.text-muted.mb-4 Enter recent acativity details.
        form(method='post' action='/add-recentActivity')
           .mb-4
            label.form-label.fw-semibold(for='plate') Plate
            input#plate.form-control(type='text' name='plate' )
            label.form-label.fw-semibold(for='driver') Driver
            input#driver.form-control(type='text' name='driver' )
            label.form-label.fw-semibold(for='action') Action
            input#action.form-control(type='text' name='action' )
          button.btn.btn-primary.w-100.py-2.fw-bold.rounded-3(type='submit') Add Recent Activity
  script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')