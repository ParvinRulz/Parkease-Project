doctype html
html(lang='en')
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title ParkVille Tyre Clinic

    // Bootstrap CSS
    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')

    // Custom Styles
    style.
      .dark-blue {
        background-color: #0d1b2a !important;
        color: #fff !important;
      }

      .dark-blue-outline {
        border: 1px solid #0d1b2a !important;
        color: #0d1b2a !important;
        background-color: transparent !important;
      }

      .yellow-btn {
        background-color: #ffc107 !important;
        color: #000 !important;
        border: none !important;
      }

      .yellow-btn:hover {
        background-color: #e0a800 !important;
        color: #000 !important;
      }

  body
    // Navbar
    nav.navbar.navbar-expand-lg.dark-blue.px-3
      a.navbar-brand.text-white(href='#')
        h2.mb-0 ParkVille

      button.navbar-toggler(
        type='button'
        data-bs-toggle='collapse'
        data-bs-target='#navbarNav'
      )
        span.navbar-toggler-icon

      #navbarNav.collapse.navbar-collapse
        ul.navbar-nav.me-auto
          li.nav-item
            a.nav-link.text-white(href='reports.html') Reports
          li.nav-item
            a.nav-link.text-white(href='attendantdashboard.html') Attendant
          li.nav-item
            a.nav-link.text-white(href='register.html') Register
          li.nav-item
            a.nav-link.text-white(href='battery.html') Battery
          li.nav-item
            a.nav-link.active.text-white(href='tyreClinic.html') Tyre Clinic
          li.nav-item
            a.nav-link.text-white(href='signout.html') Signout
          li.nav-item
            a.nav-link.text-white(href='login.html') Logout

        form.d-flex
          input.form-control.me-2(type='search' placeholder='Search inventory...')
          button.btn.yellow-btn(type='submit') Sign In

    // MAIN
    .container.my-5
      .row
        // Sidebar
        aside.col-lg-3.mb-4
          .card.text-center.shadow-sm.p-3.mt-3
            h5 Current Tyre Management
            p Ensure your heavy-duty vehicles never stop with our on-site replacement service.
            button.btn.yellow-btn.mb-3 Manage Tyre
            img.img-fluid(src='Assests/three-tyre.png' alt='three tires')

        // Main Content
        main.col-lg-9
          // Hero
          section.row.align-items-center.mb-5
            .col-lg-6
              span.badge.bg-warning.mb-2 PROFESSIONAL GRADE
              h1
                | Premium
                br
                | Heavy-Duty
                br
                | Tyre Clinic
              p.text-muted
                | Reliable replacements and long-term hire solutions for industrial vehicles and heavy fleets. Built for endurance.
              .d-flex.flex-column.flex-md-row.gap-2
                button.btn.yellow-btn View Inventory
                button.btn.dark-blue-outline Custom Quote

            .col-lg-6.text-center
              img.img-fluid(src='Assests/black-tyre.PNG' alt='tire')

          // Inventory Form
          section.mb-5
            h2.mb-4 Inventory

            form(method='post' action='')
              .row.g-3
                .col-md-6
                  label.form-label.fw-semibold(for='tireType') Tire Type
                  select#tireType.form-select(name='tireType')
                    option(value='') Select tyre type
                    option(value='Bridgestone') Bridgestone
                    option(value='Goodyear') Goodyear
                    option(value='CEAT') CEAT
                    option(value='Continental') Continental

                .col-md-6
                  label.form-label.fw-semibold(for='tyreSize') Tire Size
                  select#tyreSize.form-select(name='tyreSize')
                    option(value='') Select tyre size
                    option(value='15 inch') 15 inch
                    option(value='16 inch') 16 inch
                    option(value='17 inch') 17 inch
                    option(value='18 inch') 18 inch

                .col-md-6
                  label.form-label.fw-semibold(for='tireService') Tire Service
                  select#tireService.form-select(name='tireService')
                    option(value='') Select tire service
                    option(value='pressure') Pressure
                    option(value='puncture-fixing') Puncture Fixing
                    option(value='valves') Valves

          // Why Section
          section.row.align-items-center.mb-5
            .col-md-6
              h3 Why Hire from ParkVille?
              ul.list-unstyled
                li ✔ Certified Quality Tyres
                li ✔ 24/7 Emergency Support

            .col-md-6.d-flex.gap-4
              .text-center.flex-fill.p-3.bg-light.rounded.shadow
                h2 15k+
                p Tires deployed annually

    // Footer
    footer.dark-blue.pt-4.pb-3
      .container
        .row.mb-3
          .col-md-3
            h5 ParkVille
            p The global standard in vehicle, battery and tyre maintenance.

          .col-md-3
            h6 Services
            p Emergency Replacement
            p Smart Parking
            p Vehicle Maintenance

          .col-md-3
            h6 Resources
            p Safety Guides
            p Tire Maintenance
            p Pricing Calculator

          .col-md-3
            h6 Contact
            p parvin.parkville@par.com
            p +256 777 000000

    // Bootstrap JS
    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')