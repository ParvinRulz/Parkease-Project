doctype html
html(lang='en')
  head
    meta(charset='utf-8')
    meta(name='viewport' content='width=device-width, initial-scale=1')
    title Section Manager Dashboard
    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css' rel='stylesheet')

    style.
      .dark-blue {
        background-color: #0f172a !important;
      }
      .dark-blue a,
      .dark-blue .navbar-brand,
      .dark-blue p {
        color: #fff !important;
      }

  body

    // NAVBAR
    nav.navbar.navbar-expand-lg.dark-blue
      .container-fluid
        a.navbar-brand(href='#') Manager Dashboard
        button.navbar-toggler(type='button' data-bs-toggle='collapse' data-bs-target='#navbarNav')
          span.navbar-toggler-icon
        #navbarNav.collapse.navbar-collapse
          ul.navbar-nav
            li.nav-item
              a.nav-link.active(href='#') Admin
            li.nav-item
              a.nav-link(href='#') Attendant
            li.nav-item
              a.nav-link(href='#') Pricing

    .container.mt-4

      // DASHBOARD CARDS (DYNAMIC VALUES)
      .row.g-4.mb-4
        .col-md-4
          .card.shadow.p-3.text-center
            h5 Total Parking Slots
            h2.text-primary= totalSlots

        .col-md-4
          .card.shadow.p-3.text-center
            h5 Occupied Slots
            h2.text-danger= occupiedSlots

        .col-md-4
          .card.shadow.p-3.text-center
            h5 Today's Revenue
            h2.text-success= todaysRevenue

      // RECENT PARKING ACTIVITY
      .card.shadow.mb-4
        .card-body
          h5.mb-3 Recent Parking Activity
          table.table
            thead
              tr
                th Receipt Number
                th Number Plate
                th In Time
                th Out Time
                th Duration
                th Fee
            tbody
              if parkingActivities && parkingActivities.length
                each activity in parkingActivities
                  tr
                    td= activity.receipt
                    td= activity.plate
                    td= activity.inTime
                    td= activity.outTime
                    td= activity.duration
                    td= activity.fee
              else 
                  tr
                    td(colspan="6") No parking activity available

      // DAILY TOTAL (SEPARATE — NOT INSIDE TABLE)
      .row.mb-4
        .col-md-4
          .card.shadow.p-3.text-center
            span DAILY GRAND TOTAL :
            h2= dailyTotal

      // SERVICE TRANSACTIONS SECTION
      .card.shadow.mb-4
        .card-body
          h5.mb-3 Service Transactions
          a.btn.btn-primary(href='/transactions/new') Record New Transaction
          table.table.mt-3
            thead
              tr
                th Service
                th Customer
                th Amount
                th Date
            tbody
              each service in services
                tr
                  td= service.name
                  td= service.customer
                  td= service.amount
                  td= service.date

      // PRICING SECTION
      .card.shadow.mb-4
        .card-body
          h5.mb-3 Service Pricing
          a.btn.btn-warning(href='/pricing') Set Prices for Tyres & Batteries
          table.table.mt-3
            thead
              tr
                th Item
                th Price
            tbody
              each price in pricing
                tr
                  td= price.item
                  td= price.amount

    // FOOTER
    footer.footer.dark-blue.text-center.p-3.mt-4
      p SECTION MANAGER CONTROL PANEL
      p © 2026 ParkEase Smart Systems

    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js')