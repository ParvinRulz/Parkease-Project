doctype html
head
  meta(charset='utf-8')
  meta(name='viewport' content='width=device-width, initial-scale=1')
  title Manager Dashboard
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css' rel='stylesheet' integrity='sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB' crossorigin='anonymous')
nav.navbar.navbar-expand-lg.bg-body-tertiary
  .container-fluid
    a.navbar-brand(href='#') Manager Dashboard
    button.navbar-toggler(type='button' data-bs-toggle='collapse' data-bs-target='#navbarNav' aria-controls='navbarNav' aria-expanded='false' aria-label='Toggle navigation')
      span.navbar-toggler-icon
    #navbarNav.collapse.navbar-collapse
      ul.navbar-nav
        li.nav-item
          a.nav-link.active(aria-current='page' href='#') Admin
        li.nav-item
          a.nav-link(href='#') Attendant
        li.nav-item
          a.nav-link(href='#') Pricing
.row.g-4.mb-4
  .col-md-4
    .card.shadow.dashboard-card.p-3.text-center
      h5 Total Parking Slots
      h2.text-primary 120
  .col-md-4
    .card.shadow.dashboard-card.p-3.text-center
      h5 Occupied Slots
      h2.text-danger 85
  .col-md-4
    .card.shadow.dashboard-card.p-3.text-center
      h5 Today&apos;s Revenue
      h2.text-success UGX 450,000
// Parking Activity Table
.card.shadow.mb-4
  .card-body
    h5.mb-3 Recent Parking Activity
    table.table
      thead
        tr
          th(scope='col') Receipt Number
          th(scope='col') Number Plate
          th(scope='col') IN-TIME
          th(scope='col') OUT-TIME
          th(scope='col') DURATION
          th(scope='col') FEE
      tbody
        tr
          td #PE-98231
          td UAA 214A
          td 08:15 AM
          td 05:30 PM
          td 9h 15m
          td UGX 25,000
        tr
          td #PE-98232
          td UBB 673B
          td 09:00 AM
          td 02:15 PM
          td 5h 15m
          td UGX 15,000
        tr
          td #PE-98233
          td UAX 982X
          td 10:30 AM
          td 06:45 PM
          td 8h 15m
          td UGX 22,000
    .col-md-4
      .card.shadow.dashboard-card.p-3.text-center
        span DAILY GRAND TOTAL :
        h2 UGX 6,790,000
    footer.footer
      p SECTION MANAGER CONTROL PANEL
      p &copy; 2026 ParkEase Smart Systems
    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js' integrity='sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI' crossorigin='anonymous')
