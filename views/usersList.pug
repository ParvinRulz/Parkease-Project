doctype html
html(lang='en')
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title Users List

    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css' rel='stylesheet')

    style.
      body {
        background-color: #f8fafc;
      }

      .custom-navbar,
      .custom-footer {
        background-color: #0f172a !important;
      }

      .custom-navbar .nav-link,
      .custom-navbar .navbar-brand {
        color: #fff !important;
      }

      .custom-navbar .nav-link.active {
        font-weight: bold;
      }

      .dashboard-card {
        border-radius: 12px;
      }

  body.d-flex.flex-column.min-vh-100

    // ================= NAVBAR =================
    nav.navbar.navbar-expand-lg.bg-white.shadow-sm
      .container-fluid

        a.navbar-brand.fw-bold(style='color:#0f172a;' href='/login') ParkVille

        button.navbar-toggler(type='button' data-bs-toggle='collapse' data-bs-target='#navbarNav')
          span.navbar-toggler-icon

        #navbarNav.collapse.navbar-collapse
          ul.navbar-nav.me-auto.mb-2.mb-lg-0
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/signup") Signup
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/login") Login
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/login") Dashboard
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/users") Manage Users
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/registerVehicle") Vehicle
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/signout") Vehicle Signout
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/battery") Battery Services
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/tyre") Tyre Clinic

    // MAIN CONTENT
    main.container.mt-5.flex-grow-1

      // CARD SUMMARY
      .row.mb-4
        .col-md-4
          .card.shadow.dashboard-card.p-3.text-center
            h5 USER REPORTS
            img(src='/Images/users.jpg', style='width:150px;')

      // TABLE
      .card.shadow-sm
        .card-body
          .table-responsive
            table.table.table-hover.align-middle
              thead.table-light
                tr
                  th First Name
                  th Last Name
                  th Email
                  th Phone
                  th Role
              tbody
                if users.length
                  each user in users
                    tr
                      td #{user.firstName}
                      td #{user.lastName}
                      td #{user.email}
                      td #{user.phoneNumber}
                      td #{user.role}
                else
                  tr
                    td.text-center.py-4.text-muted(colspan="5") No users found.

    // FOOTER
    footer.custom-footer.text-white.text-center.py-3.mt-auto
      small © Parvin 2026 ParkVille System

    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js')