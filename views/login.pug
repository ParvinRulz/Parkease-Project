doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1')
    title Login Page

    // Bootstrap CSS
    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')

    // Custom styles
    style.
      .link-yellow {
        color: #0f172a !important;
        text-decoration: none;
      }
      .link-yellow:hover {
        color: #0f172a !important;
        text-decoration: underline;
      }
      .btn-outline-dark:hover {
        background-color: #0f172a !important;
      }

  body
    // Center container
    .container.min-vh-100.d-flex.justify-content-center.align-items-center

      // Card
      .card.shadow-lg.p-4.border-0.rounded-4(style='max-width: 400px; width: 100%;')

        // Logo
        .text-center.mb-3
          img(src='/Images/logo.png' alt='ParkVille Logo' style='width: 80px;')
          h4.mt-2.fw-bold ParkVille

        // Heading
        .text-center.mb-3
          h5.fw-bold Welcome back
          p.text-muted.small Please enter your details to sign in

        // Form
        form
          .mb-3
            label.form-label Username
            input.form-control(type='text' placeholder='Enter your username')

          .mb-2
            label.form-label Password
            .d-flex.align-items-center
              input.form-control(type='password' placeholder='Enter your password')
              a.ms-2.small.link-yellow(href='#') Forgot?

          .form-check.mb-3
            input#remember.form-check-input(type='checkbox')
            label.form-check-label(for='remember') Keep me logged in

          button.btn.btn-warning.w-100.fw-semibold(type='submit')
            | Sign In &rarr;

        // Divider
        .text-center.my-3.text-muted.small OR CONTINUE WITH

        // Social Buttons
        .d-flex.gap-2.mb-3
          button.btn.btn-outline-dark.w-50 Google
          button.btn.btn-outline-dark.w-50 iOS

        // Signup
        .text-center.small.mb-3
          | Don’t have an account?
          a.link-yellow(href='#') Create account

        // Footer
        .text-center.small
          a.link-yellow.me-2(href='#') Help Center
          a.link-yellow.me-2(href='#') Terms
          a.link-yellow(href='#') Privacy

    // Bootstrap JS
    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')