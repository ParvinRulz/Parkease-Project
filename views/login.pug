doctype html
html(lang='en')
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1')
    title Login Page

    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')

    style.
      body {
        background: linear-gradient(to right, #f8fafc, #e2e8f0);
      }

      .dark-blue {
        color: #0f172a;
      }

      .link-yellow {
        color: #0f172a !important;
        text-decoration: none;
      }

      .login-card {
        border-radius: 20px;
      }

      .form-control {
        border-radius: 10px;
        padding: 10px;
      }

      .form-control:focus {
        box-shadow: 0 0 0 2px rgba(255,193,7,0.3);
        border-color: #ffc107;
      }

      .btn-warning {
        background-color: #ffc107 !important;
        border: none;
      }

      .btn-warning:hover {
        background-color: #e0a800 !important;
      }

  body
    .container.min-vh-100.d-flex.align-items-center.justify-content-center

      .row.shadow-lg.bg-white.overflow-hidden(style='max-width: 850px; width:100%; border-radius:20px;')

        // LEFT SIDE (branding / info)
        .col-md-5.d-none.d-md-flex.flex-column.justify-content-center.align-items-center.text-center.p-4(style='background-color:#0f172a; color:white;')
          img(src='/Images/logo.png' style='width:70px;')
          h4.mt-3.fw-bold ParkVille
          p.small.mt-2
            | Intergrated Parking & Vehicle Services Management System offering Tyre Clinic & Battery Hire Services with efficiency and security.

        // RIGHT SIDE (form)
        .col-md-7.p-4.p-md-5

          .text-center.mb-4
            h4.fw-bold.dark-blue Welcome Back
            p.text-muted.small Sign in to continue

          form(action="/login" method="POST")

            .mb-3
              label.form-label.fw-semibold Username
              input.form-control(type='text' placeholder='Andrew Semyalo')

            .mb-3
              label.form-label.fw-semibold(for='email') Email Address
              input#email.form-control(type='email' placeholder='name@example.com' name='email')

            .mb-3
              label.form-label.fw-semibold(for='password') Password
              input#password.form-control(type='password' placeholder='••••••••' name='password')

            .d-flex.justify-content-between.align-items-center.mb-3
              .form-check
                input#remember.form-check-input(type='checkbox')
                label.form-check-label(for='remember') Remember me
              a.small.link-yellow(href='#') Forgot password?

            button.btn.btn-warning.w-100.fw-semibold.py-2(type='submit')
              | Log In →

            .text-center.mt-4
              p.mb-0.text-muted
                | Don&apos;t have an account?
                a.fw-semibold.ms-1.link-yellow(href='/auth/signup') Sign up

          .text-center.small.mt-4
            a.link-yellow.me-2(href='#') Help Center
            a.link-yellow.me-2(href='#') Terms
            a.link-yellow(href='#') Privacy

    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')