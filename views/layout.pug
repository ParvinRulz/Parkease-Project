doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title Log In

    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')
    link(href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css' rel='stylesheet')
    link(rel='stylesheet' href='/css/style.css')

    style.
      body {
        background-color: #f4f7f6;
      }

      .dark-nav {
        background-color: #0f172a !important;
      }

      .yellow-btn {
        background-color: #ffc107 !important;
        color: #000 !important;
        border: none !important;
      }

      .yellow-btn:hover {
        background-color: #e0a800 !important;
        color: #000 !important;
      }

  body.d-flex.flex-column.min-vh-100

    // NAVBAR (NOW DARK BLUE)
    nav.navbar.navbar-expand-lg.navbar-dark.dark-nav
      .container-fluid
        a.navbar-brand(href='/auth/login') ParkVille

        button.navbar-toggler(type='button' data-bs-toggle='collapse' data-bs-target='#navbarSupportedContent')
          span.navbar-toggler-icon

        #navbarSupportedContent.collapse.navbar-collapse
          ul.navbar-nav.me-auto.mb-2.mb-lg-0
            li.nav-item
              a.nav-link(href="/") Home

            if user
              if user.role === "Admin"
                li.nav-item
                  a.nav-link(href="/admin") Dashboard
                li.nav-item
                  a.nav-link(href="/usersList") Manage Users

              if user.role === "Manager"
                li.nav-item
                  a.nav-link(href="/manager") Dashboard
                li.nav-item
                  a.nav-link(href="/registerBattery") Battery Services
                li.nav-item
                  a.nav-link(href="/tyreServices") Tyre Clinic

              if user.role === "Attendant"
                li.nav-item
                  a.nav-link(href="/attendant") Dashboard
                li.nav-item
                  a.nav-link(href="/registerVehicle") Check in
                li.nav-item
                  a.nav-link(href="/signout") Vehicle Signout

          .d-flex.ms-lg-3.align-items-center
            if user
              span.text-light.me-3.small
                i.fa-solid.fa-user-circle.me-1
                | Hi, #{user.firstName}
                span.badge.bg-secondary.ms-1 #{user.role}

              a.btn.btn-outline-danger.btn-sm.fw-bold(href="/auth/logout") Log Out
            else
              a.btn.yellow-btn.me-2(href="/login") Log in

    // PAGE CONTENT
    main.flex-grow-1
      block content

    // FOOTER (NOW DARK BLUE)
    footer.dark-nav.text-white.py-4.mt-auto
      .container.text-center
        p.mb-0 &copy; 2026 ParkVille Park System. All Rights Reserved