doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title Log In

    // Bootstrap & Icons
    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')
    link(href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css' rel='stylesheet')

    // Custom CSS
    link(rel='stylesheet' href='/css/style.css')

    style.
      body {
        background-color: #f4f7f6;
      }

      .dark-nav {
        background-color: #0f172a !important;
      }

      .yellow-btn {
        background-color: #ffc107 !important;
        color: #000 !important;
        border: none !important;
      }

      .yellow-btn:hover {
        background-color: #e0a800 !important;
        color: #000 !important;
      }

  body.d-flex.flex-column.min-vh-100
    // ================= NAVBAR =================
    nav.navbar.navbar-expand-lg.bg-white.shadow-sm
      .container-fluid

        a.navbar-brand.fw-bold(style='color:#0f172a;' href='/login') ParkVille

        button.navbar-toggler(type='button' data-bs-toggle='collapse' data-bs-target='#navbarNav')
          span.navbar-toggler-icon

        #navbarNav.collapse.navbar-collapse
          ul.navbar-nav.me-auto.mb-2.mb-lg-0
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/signup") Signup
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/login") Login
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/login") Dashboard
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/users") Manage Users
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/registerVehicle") Vehicle
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/signout") Vehicle Signout
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/battery") Battery Services
            li.nav-item
              a.nav-link(style='color:#0f172a;' href="/tyre") Tyre Clinic

    
          // RIGHT SIDE (USER / AUTH)
          .d-flex.ms-lg-3.align-items-center
            if user
              span.text-light.me-3.small
                i.fa-solid.fa-user-circle.me-1
                | Hi, #{user.firstName}
                span.badge.bg-secondary.ms-1 #{user.role}

              a.btn.btn-outline-danger.btn-sm.fw-bold(href="/auth/logout") Log Out
            else
              a.btn.yellow-btn.me-2(href="/login") Log in


    // ================= PAGE CONTENT =================
    main.flex-grow-1
      block content


    // ================= FOOTER =================
    footer.dark-nav.text-white.py-4.mt-auto
      .container.text-center
        p.mb-0 © Parvin 2026 ParkVille Park System. All Rights Reserved