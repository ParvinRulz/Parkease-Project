doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title Sign-out and Receipting
  link(rel='stylesheet' href='CSS/signout.css')
//
  =========================
  SIDE NAVIGATION BAR
  Contains links to all system pages
  =========================
nav.top-navbar
  // System title/logo
  .nav-logo
    h2 ParkEase
  // Navigation links
  ul.nav-links
    // Admin Revenue Reports page
    li
      a(href='reports.html') Reports
    // Register vehicles page
    li
      a(href='register.html') Register
    // Parking attendants page
    li
      a(href='attendants.html') Attendants
    // Vehicle sign out page
    li
      a(href='signout.html') Sign Out
    // Battery hire services
    li
      a(href='battery.html') Battery
    // Tyre services page
    li
      a(href='tyre.html') Tyre
br
input.search(type='text' placeholder='Search Receipt by ID or Plate Number')
.user
  span Parvin Rulz
  span.role ATTENDANT
.container
  h1 Vehicle &amp; Arrival Details
  p.subtitle Review parking details and confirm payment
  .layout
    // Left Side
    .left
      .vehicle
        img.truck(src='Assests/truck.png')
        .vehicle-text
          h3 John Baptist Ssemuwemba
          p Heavy Truck (T-04)
          .times
            div
              span Arrival Time
              p 10:24 AM
            div
              span Stay Duration
              p 4h 20m
      .fee
        span CALCULATED PARKING FEE
        h2 UGX 17,500
      .receiver
        h3 Receiver Information
        .form-grid
          div
            label Full Name
            input(type='text' value='John Baptist Ssemuwemba')
          div
            label Phone Number
            input(type='text' value='+256')
          div
            label NIN Number
            input(type='text' value='CMD000000000AAA')
          div
            label Gender
            select
              option Male
              option Female
          div
            label Payment Methods
            select
              option Mobile Money
              option Cash
      .buttons
        button.confirm
          | Confirm Payment &amp; Sign-out
        button.cancel
          | Cancel
    // Right Side Receipt
    .receipt
      .receipt-logo
        img(src='Assests/logo-P.png' alt='parkease-logo' width='100')
      h3 PARKEASE
      p.address
        | Plot 28 Kampala Central 
        br
        | +256 789 000000
      hr
      .receipt-row
        span Receipt ID
        span #PE-2023-49812
      .receipt-row
        span Date/Time
        span Oct 24, 2023 02:44 PM
      hr
      .receipt-row
        span Vehicle Reg
        span UBA 123X
      .receipt-row
        span Vehicle Class
        span Heavy Truck (T-04)
      .receipt-row
        span Entry Time
        span 10:24 AM
      .receipt-row
        span Stay Duration
        span 4h 20m
      hr
      .total
        span Total Amount
        h2 UGX 17,500
      .qr
        img(src='Assests/qr.jpg' alt='qr code')
        p SCAN TO VERIFY
