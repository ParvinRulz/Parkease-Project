extends layout

block content
  // Page-specific styling ONLY
  style.
    /* Turn ONLY existing navbar dark blue */
    .navbar {
      background-color: #0d1b2a !important;
    }

    .navbar .nav-link,
    .navbar .navbar-brand {
      color: #fff !important;
    }

    .navbar .nav-link.active {
      font-weight: bold;
    }
    .yellow-btn {
        background-color: #ffc107 !important;
        color: #000 !important;
        border: none !important;
      }

      .yellow-btn:hover {
        background-color: #e0a800 !important;
        color: #000 !important;
      }

  .container.min-vh-100.d-flex.justify-content-center.align-items-center
    .card.shadow-lg.border-0.rounded-4(style='width: 100%; max-width: 450px;')
      .card-body.p-5
        h2.text-center.fw-bold.mb-2 Vehicle Signout
        p.text-center.text-muted.mb-4 Please enter your receipt to process your signout

        form(method='post' action='/signout/verify')
          .mb-3
            label.form-label.fw-semibold(for='receiptNumber') Receipt Number
            input#receiptNumber.form-control(
              type='text'
              placeholder='e.g RCPT-abcd123'
              name='receiptNumber'
            )

          button.btn.yellow-btn.w-100.py-2.fw-bold.rounded-3(type='submit')
            | Verify Receipt

  script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')